generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["schemaEngineDriverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String  @unique(map: "product_slug_key")
  category    String
  description String
  /// sku         String  @unique
  // images      String[]
  brand       String
  stock       Int     @default(0)
  currency    String  @default("USD")
  price       Decimal @default(0) @db.Decimal(12, 2)
  rating      Decimal @default(0) @db.Decimal(3, 2)
  numReviews  Int     @default(0)
  isFeatured  Boolean @default(false)
  banner      String?

  // Relations
  images   ProductImage[]
  features ProductFeature[]
  tags     ProductTag[]

  // Specifications
  material      String?
  capacity      String?
  color         String?
  finish        String?
  style         String?
  compatibility String?
  size          String?
  printType     String?

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url       String
  alt       String?
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProductFeature {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feature   String
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductTag {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tag       String
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model User {
  id              String    @id
  name            String    @default("NO NAME")
  email           String    @unique(map: "user_email_key")
  userName        String?   @unique(map: "user_user_name_key")
  emailVerified   Boolean?  @default(false)
  image           String?
  password        String?
  phoneNumber     String?   @unique(map: "user_phoneNumber_key")
  gender          String?
  dateOfBirth     DateTime? @db.Timestamp(6)
  reputation      Int       @default(0)
  bio             String?
  businessName    String?
  businessAddress String?
  otherNumber     String?
  cashBack        Decimal   @default(500) @db.Decimal(12, 2)
  totalJobs       Int       @default(0)
  totalSpent      Decimal   @default(0) @db.Decimal(12, 2)
  totalDebits     Decimal   @default(0) @db.Decimal(12, 2)
  totalCredit     Decimal   @default(0) @db.Decimal(12, 2)
  role            String    @default("USER")
  addresses       Json      @default("[]") @db.Json
  paymentMethods  String?
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  accounts        Account[]
  cart            Cart[]
  sessions        Session[]
  sales           Booking[]
  debts           Debts[]
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@unique([identifier, value])
}

model Cart {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?
  sessionCartId String
  items         Json[]   @default([]) @db.Json
  itemssPrice   Decimal  @db.Decimal(12, 2)
  totalPrice    Decimal  @db.Decimal(12, 2)
  shippingPrice Decimal  @db.Decimal(12, 2)
  taxPrice      Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Booking {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String
  jobType       String
  jobDetails    String
  status        String   @default("PENDING")
  quantity      Int
  cost          Decimal  @db.Decimal(12, 2)
  deposit       Decimal  @db.Decimal(12, 2)
  balance       Decimal  @db.Decimal(12, 2)
  overpaid      Decimal  @default(0) @db.Decimal(12, 2)
  paymentMethod String
  deliveryDate  DateTime @default(now()) @db.Timestamp(6)
  totalPrice    Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  user          User     @relation(fields: [userId], references: [id])
}

model Debts {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String
  bookingId     String
  paymentMethod String
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  user          User     @relation(fields: [userId], references: [id])
}
